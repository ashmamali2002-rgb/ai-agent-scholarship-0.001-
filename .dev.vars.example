# Copy this file to .dev.vars and fill in your API keys
# .dev.vars is gitignored — never commit real keys

GROQ_API_KEY=your_groq_api_key_here
SERPER_API_KEY=your_serper_api_key_here
JINA_API_KEY=your_jina_ai_api_key_here
RESEND_API_KEY=your_resend_api_key_here

# Optional: once you verify a domain in Resend, set a real From address here.
# Until then leave it unset and the app uses the Resend sandbox sender.
RESEND_FROM=

# Supabase (multi-user auth + database + storage)
# From Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Legacy service_role key (secret) — only needed for admin/background tasks
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Secret that protects the scheduled pool-refresh endpoint.
# Use any long random string; set the SAME value as a GitHub Actions secret.
REFRESH_SECRET=your_long_random_refresh_secret_here
